# ===========================================================================
# .gitignore — Literatus Novelist Monorepo
# ===========================================================================

# ---------------------------------------------------------------------------
# Python / Django
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Migraciones generadas automáticamente (opcional: comenta si deseas versionar)
# */migrations/*.py
# */migrations/*.pyc

# Base de datos SQLite local
*.sqlite3
db.sqlite3

# Static files (Django)
backend/static/
backend/staticfiles/

# ---------------------------------------------------------------------------
# Entornos virtuales — NO subir al repositorio
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Variables de entorno sensibles — NUNCA subir al repositorio
# ---------------------------------------------------------------------------
.env
!.env.example

# ---------------------------------------------------------------------------
# Archivos de sistema
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDEs y editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Frontend (Angular / Node)
# ---------------------------------------------------------------------------
node_modules/
.angular/
dist/
.next/
out/
.nuxt/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Multimedia y Binarios (S3 futuro)
# ---------------------------------------------------------------------------
backend/media/
*.mp3
*.wav
*.png
*.jpg
*.jpeg

# ---------------------------------------------------------------------------
# Libros y Activos de Importación
# ---------------------------------------------------------------------------
assets_to_import/
*.epub
*.pdf
