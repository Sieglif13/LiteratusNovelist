# ===========================================================================
# .gitignore — Literatus Novelist Monorepo
# ===========================================================================

# ---------------------------------------------------------------------------
# Python / Django
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Migraciones generadas automáticamente (opcional: comenta si deseas versionar)
# */migrations/*.py
# */migrations/*.pyc

# Base de datos SQLite local (solo para desarrollo rápido)
*.sqlite3
db.sqlite3

# ---------------------------------------------------------------------------
# Entornos virtuales — NO subir al repositorio
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Variables de entorno sensibles — NUNCA subir al repositorio
# ---------------------------------------------------------------------------
.env
!.env.example

# ---------------------------------------------------------------------------
# Archivos de sistema
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDEs y editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.nuxt/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
