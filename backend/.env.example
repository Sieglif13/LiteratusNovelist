# ---------------------------------------------------------------------------
# Template de variables de entorno para Literatus Novelist - Backend
# Copia este archivo a .env y rellena tus valores locales.
# NUNCA subas el archivo .env real al repositorio.
# ---------------------------------------------------------------------------

# Activar modo depuración (True solo en desarrollo local)
DEBUG=True

# Clave secreta de Django — genera una nueva en producción
SECRET_KEY=django-insecure-reemplaza-esta-clave-con-una-propia

# URL de conexión a la base de datos PostgreSQL
# Formato: postgres://<usuario>:<contraseña>@<host>:<puerto>/<nombre_db>
DATABASE_URL=postgres://postgres:tu_contraseña@localhost:5432/literatus_db

# Hosts permitidos (lista separada por comas)
ALLOWED_HOSTS=localhost,127.0.0.1
